{
  "version": 2,
  "builds": [
    {
      "src": "front/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": { "maxDuration": 300 }
    },
    {
      "src": "api/upload.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    {
      "source": "/api/upload",
      "destination": "api/upload.js"
    },
    {
      "source": "/api/(.*)",
      "destination": "api/index.py"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
