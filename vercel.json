{
  "version": 2,
  "functions": {
    "api/**/*.py": {
      "maxDuration": 300
    }
  },
  "rewrites": [
    { "source": "/api/upload", "destination": "/api/upload.mjs" },
    { "source": "/api/(.*)", "destination": "/api/index.py" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
