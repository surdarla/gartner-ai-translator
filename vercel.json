{
  "version": 2,
  "functions": {
    "api/index.py": {
      "maxDuration": 300
    },
    "api/upload.mjs": {
      "runtime": "nodejs20.x"
    }
  },
  "rewrites": [
    {
      "source": "/api/upload",
      "destination": "api/upload.mjs"
    },
    {
      "source": "/api/(.*)",
      "destination": "api/index.py"
    },
    {
      "source": "/(.*)",
      "destination": "front/$1"
    }
  ]
}
