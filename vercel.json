{
  "version": 2,
  "builds": [
    {
      "src": "front/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "api/upload.mjs",
      "use": "@vercel/node"
    }
  ],
  "functions": {
    "api/**/*.py": {
      "maxDuration": 300
    },
    "api/upload.mjs": {
      "runtime": "nodejs20.x"
    }
  },
  "rewrites": [
    {
      "source": "/api/upload",
      "destination": "api/upload.mjs"
    },
    {
      "source": "/api/(.*)",
      "destination": "api/index.py"
    },
    {
      "source": "/(.*)",
      "destination": "front/$1"
    },
    {
      "source": "/(.*)",
      "destination": "front/index.html"
    }
  ]
}
